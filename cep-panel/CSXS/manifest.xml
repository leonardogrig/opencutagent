<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="9.0"
    ExtensionBundleId="com.opencutagent.bundle"
    ExtensionBundleVersion="0.1.0"
    ExtensionBundleName="OpenCutAgent"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <ExtensionList>
    <Extension Id="com.opencutagent.panel" Version="0.1.0" />
  </ExtensionList>
  <ExecutionEnvironment>
    <HostList>
      <!-- PPRO = Premiere Pro. Range covers Premiere 2024–2026+. -->
      <Host Name="PPRO" Version="[24.0,99.9]" />
    </HostList>
    <LocaleList>
      <Locale Code="All" />
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="9.0" />
    </RequiredRuntimeList>
  </ExecutionEnvironment>
  <DispatchInfoList>
    <Extension Id="com.opencutagent.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./client/index.html</MainPath>
          <ScriptPath>./host/premiere.jsx</ScriptPath>
          <CEFCommandLine>
            <!-- Node.js access in the panel: needed to read the shared bridge-port file. -->
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--mixed-context</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>OpenCutAgent</Menu>
          <Geometry>
            <Size>
              <Height>340</Height>
              <Width>360</Width>
            </Size>
            <MinSize>
              <Height>200</Height>
              <Width>240</Width>
            </MinSize>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
